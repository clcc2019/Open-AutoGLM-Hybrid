# ========================================
# Reply Agent Service Configuration
# ========================================

# --- LLM Provider ---
# Supports: DeepSeek, OpenAI, Zhipu (GLM), or any OpenAI-compatible API
LLM_PROVIDER=openai_compatible
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# --- Vision LLM (for screenshot analysis) ---
# Leave empty to use the same LLM as above.
# For best results, use a vision model (gpt-4o, glm-4v-plus, etc.)
# VISION_MODEL=gpt-4o
# VISION_API_KEY=
# VISION_BASE_URL=

# --- RAG Knowledge Base ---
# Set to true to enable RAG (requires embedding config below)
ENABLE_RAG=false

# --- Embedding (for RAG, only used when ENABLE_RAG=true) ---
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_DIMENSIONS=1536

# --- Database ---
# SQLite (development):
DATABASE_URL=sqlite:///reply_agent.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://ai:ai@localhost:5532/ai

# --- Knowledge ---
KNOWLEDGE_DOCS_DIR=knowledge_docs
LANCEDB_URI=tmp/lancedb

# --- Skills ---
# Directory containing skill packages (each with SKILL.md)
SKILLS_DIR=skills

# --- MCP Servers ---
# JSON array of MCP server configurations. Examples:
# SSE transport: [{"name":"weather","url":"http://localhost:3000","transport":"sse"}]
# Stdio transport: [{"name":"fs","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"],"transport":"stdio"}]
# MCP_SERVERS=[]

# --- Security ---
# API Key for authentication (leave empty to disable auth)
API_KEY=dsong
# Custom API path prefix to obscure endpoints (default: /api)
# Example: /x3k9m7 — scanners won't guess this path
# API_PATH_PREFIX=/api
# Custom admin page path (default: /admin)
# ADMIN_PATH=/admin
# Max requests per minute per IP (0 = disabled, default: 120)
# RATE_LIMIT_RPM=120

# --- Server ---
AGENT_HOST=0.0.0.0
AGENT_PORT=6443

# --- Business Rules ---
MIN_PRICE_RATIO=0.8
AUTO_ESCALATE_KEYWORDS=投诉,举报,消协,工商,律师
